# fettle configuration (TOML).  Live location: ~/.config/fettle/config.toml
#
# Precedence (low to high):  built-in defaults  <  this file  <  command-line flags
# Every setting is optional; commented values are the built-in defaults.
# fettle refuses to read this file if it is world-writable or not owned by you/root.
# It does NOT reject a world-readable file, so if you put a secret (ai_api_key)
# below, `chmod 600` this file yourself — or better, use the ANTHROPIC_API_KEY env
# var and leave the key out of the file entirely.

# Actions to run when you invoke `fettle` with no action flags / words.
#default_actions = ["clean", "orphans", "update", "rebuild-check", "python-rebuild-check", "config-drift", "firmware-check"]

# Offer to rebuild packages with outdated deps (instead of only listing them).
#auto_rebuild = false

# Foreign / AUR packages to suppress from reports (exact names or shell globs).
#exclude_foreign = ["brave-bin", "google-chrome"]

# Orphaned packages that should never be offered for removal.
#keep_orphans = ["downgrade", "nvchecker"]

# AUR supply-chain settings.
#aur_max_age_days = 365   # a PKGBUILD older than this is flagged stale (pkg-audit)
#aur_recent_days = 21     # -A audit flags packages changed within this window RECENTLY-CHANGED
#aur_ioc_campaigns = ["aur-infected", "chaos-rat", "russian-spam"]
#aur_ioc_cache_ttl = 21600   # seconds to cache the IOC lists on disk

# Upgrade Checker (`fettle upgrade-check`) — EXPERIMENTAL, under active testing.
# STRONGLY prefer the ANTHROPIC_API_KEY env var. If you put the key here instead,
# `chmod 600` this file — fettle does NOT refuse a world-readable config, so a 644
# file leaks the key to every local user.
#ai_model = "claude-sonnet-5"
#ai_effort = "medium"          # low | medium | high — thinking depth vs cost
#ai_max_web_searches = 5       # cap forum searches per run (bounds tokens/cost)
#ai_api_key = "sk-ant-..."     # optional; never printed in full by --print-config

# Per-distro tool selection (schema finalized as each backend lands). Example:
#[updaters.arch]
#system_updater = "pacman"   # pacman | pamac
#aur_updater = "yay"         # yay | pamac | none
#[updaters.debian]
#system_updater = "apt"      # apt | nala | none
#flatpak_updater = "flatpak" # flatpak | none
#snap_updater = "snap"       # snap | none
